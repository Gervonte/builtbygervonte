#!/usr/bin/env sh

# Git GUI apps (for example, GitHub Desktop) may not expose npx on PATH.
# Prefer pnpm for this repo and fall back to local binaries when available.
# Ensure common Node install locations are available when PATH is minimal.
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.volta/bin:$PATH"
export PNPM_CONFIG_MINIMUM_RELEASE_AGE="0"

if command -v pnpm >/dev/null 2>&1; then
	pnpm exec lint-staged
elif [ -x "./node_modules/.bin/lint-staged" ]; then
	./node_modules/.bin/lint-staged
else
	npx lint-staged
fi