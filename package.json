{
  "name": "portfolio-ai",
  "version": "1.0.0",
  "type": "module",
  "description": "Professional portfolio showcasing AI-assisted and traditional development work",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm run format && next build",
    "build:analyze": "ANALYZE=true next build",
    "build:clean": "rm -rf .next && pnpm run build",
    "start": "pnpm run build && pnpm run dev",
    "start:prod": "next start",
    "lint": "eslint . --color --format=stylish",
    "lint:fix": "eslint --fix . --color --format=stylish",
    "lint:json": "eslint . --format=json",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "build:ci": "pnpm run format:check && next build",
    "cache:update": "node scripts/update-cache-version.js",
    "parse-resume": "node scripts/parse-resume.js",
    "cache:clear": "node scripts/cache-management.js clear",
    "cache:status": "node scripts/cache-management.js status",
    "build:perf": "node scripts/build-performance.js monitor",
    "build:report": "node scripts/build-performance.js compare",
    "prepare": "husky",
    "clean": "rm -rf .next && rm -rf node_modules/.cache",
    "fresh": "pnpm run clean && pnpm install && pnpm run dev",
    "check": "pnpm run type-check && pnpm run lint && pnpm run format:check",
    "fix": "pnpm run lint:fix && pnpm run format"
  },
  "dependencies": {
    "@mantine/core": "^8.3.17",
    "@mantine/hooks": "^8.3.17",
    "@mantine/notifications": "^8.3.17",
    "@tabler/icons-react": "^3.40.0",
    "@types/rellax": "^1.7.7",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "framer-motion": "^12.36.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rellax": "^1.12.1",
    "resend": "^6.9.3",
    "sakura-js": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.1.6",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
